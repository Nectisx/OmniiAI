# Copie du .env de la racine — placé ici car nodemon/prisma le lisent
# directement depuis apps/backend/.

DATABASE_URL="mysql://USER:PASSWORD@HOST:4000/omniai?sslaccept=strict"

JWT_SECRET="changez-moi-secret-jwt-tres-long-et-aleatoire-2026"
JWT_REFRESH_SECRET="changez-moi-refresh-secret-jwt-different-2026"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:3000"

GEMINI_API_KEY="AIzaSy_VOTRE_CLE_GEMINI"
GROQ_API_KEY="gsk_VOTRE_CLE_GROQ"
GITHUB_TOKEN="ghp_VOTRE_TOKEN_GITHUB"

GEMINI_RPM_LIMIT=15
GEMINI_RPD_LIMIT=1500
GEMINI_TPM_LIMIT=1000000
GROQ_RPM_LIMIT=30
GROQ_RPD_LIMIT=1000
GROQ_TPM_LIMIT=500000
GPT4O_RPM_LIMIT=10
GPT4O_RPD_LIMIT=50
GPT4O_TPM_LIMIT=300000

PYTHON_SERVICE_URL="http://localhost:5000"
PYTHON_SERVICE_SECRET="omniai-python-secret-changez-moi"

UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR="./uploads"

LOG_LEVEL="info"
LOG_DIR="./logs"

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

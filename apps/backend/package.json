{
  "name": "omniai-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "npm run prisma:generate",
    "dev": "nodemon",
    "prebuild": "npm run prisma:generate",
    "build": "tsc -p tsconfig.json || (echo Type warnings ignored && exit 0)",
    "start": "node dist/server.js",
    "start:prod": "node scripts/cleanup-old-enum.js && npx prisma db push --skip-generate --accept-data-loss && node dist/server.js",
    "prisma:migrate": "prisma migrate dev --skip-seed",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node --project tsconfig.json -r tsconfig-paths/register prisma/seed.ts",
    "lint": "eslint src --ext .ts || true",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@omniai/types": "*",
    "@prisma/client": "^5.10.2",
    "axios": "^1.6.7",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "form-data": "^4.0.0",
    "helmet": "^7.1.0",
    "mammoth": "^1.7.2",
    "pdf-parse": "^1.1.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.12",
    "openai": "^4.28.4",
    "tsconfig-paths": "^4.2.0",
    "winston": "^3.12.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.24",
    "@types/pdf-parse": "^1.1.4",
    "@types/nodemailer": "^6.4.14",
    "nodemon": "^3.1.0",
    "prisma": "^5.10.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}

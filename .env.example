# ============================================================
# OmniAI — Variables d'environnement
# Copiez ce fichier en .env (à la racine) ET en apps/backend/.env
# ============================================================

# ── Base de données TiDB Cloud (gratuit) ────────────────────
# Inscription sur https://tidbcloud.com → cluster Serverless → Connect
# Format Prisma + TiDB Cloud :
DATABASE_URL="mysql://USER:PASSWORD@HOST:4000/omniai?sslaccept=strict"
# Exemple :
# DATABASE_URL="mysql://2Dqe8abcXYZ.root:monMotDePasse@gateway01.eu-central-1.prod.aws.tidbcloud.com:4000/omniai?sslaccept=strict"

# ── Authentification JWT ────────────────────────────────────
JWT_SECRET="changez-moi-secret-jwt-tres-long-et-aleatoire-2026"
JWT_REFRESH_SECRET="changez-moi-refresh-secret-jwt-different-2026"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Serveur ─────────────────────────────────────────────────
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:3000"

# ── Clés LLM (toutes gratuites, sans carte bancaire) ────────
# Gemini : https://aistudio.google.com/apikey
GEMINI_API_KEY="AIzaSy_VOTRE_CLE_GEMINI"

# Groq (Llama 3.3 70B) : https://console.groq.com/keys
GROQ_API_KEY="gsk_VOTRE_CLE_GROQ"

# GitHub Models (GPT-4o) : https://github.com/settings/tokens
# Generate new token (classic) — aucun scope nécessaire
GITHUB_TOKEN="ghp_VOTRE_TOKEN_GITHUB"

# ── Quotas free tier (valeurs par défaut) ───────────────────
GEMINI_RPM_LIMIT=15
GEMINI_RPD_LIMIT=1500
GEMINI_TPM_LIMIT=1000000
GROQ_RPM_LIMIT=30
GROQ_RPD_LIMIT=1000
GROQ_TPM_LIMIT=500000
GPT4O_RPM_LIMIT=10
GPT4O_RPD_LIMIT=50
GPT4O_TPM_LIMIT=300000

# ── Microservice Python (PDF, DOCX, STT) ────────────────────
PYTHON_SERVICE_URL="http://localhost:5000"
PYTHON_SERVICE_SECRET="omniai-python-secret-changez-moi"

# ── Upload ──────────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR="./uploads"

# ── Logs ────────────────────────────────────────────────────
LOG_LEVEL="info"
LOG_DIR="./logs"

# ── Rate limiting global Express ────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
